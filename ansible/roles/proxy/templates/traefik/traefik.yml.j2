---
# Traefik Static Configuration
global:
  checkNewVersion: true
  sendAnonymousUsage: false

# Entry Points
entryPoints:
  web:
    address: ":{{ traefik_http_port }}"
    # http:
      # redirections:
      #   entryPoint:
      #     to: websecure
      #     scheme: https
      #     permanent: true

  websecure:
    address: ":{{ traefik_https_port }}"
    http:
      tls: {}

# API and Dashboard
api:
  dashboard: {{ traefik_dashboard_enabled | lower }}
  insecure: false

# Ping endpoint for health checks
ping:
  entryPoint: "web"

{% if cloudflare_proxy_enabled | default(false) %}
# No certificate resolver needed - using Cloudflare Origin certs
{% else %}
# Certificate Resolvers (Let's Encrypt)
certificatesResolvers:
  letsencrypt:
    acme:
      email: {{ traefik_acme_email }}
      storage: /letsencrypt/acme.json
      # httpChallenge:
      #   entryPoint: web
      dnsChallenge:
        provider: cloudflare
{% endif %}

# Providers
providers:
  docker:
    endpoint: "unix:///var/run/docker.sock"
    exposedByDefault: false
    network: {{ edge_network }}
    watch: true

  file:
    directory: /etc/traefik/dynamic
    watch: true

# Logging
log:
  level: INFO
  format: common

# Access Logs
accessLog:
  format: common
  bufferingSize: 100
